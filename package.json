{
  "name": "@takara-ai/miru-code",
  "version": "1.2.0",
  "description": "Miru (見る) — hybrid code search for agents. Bun, TypeScript, Takara embeddings.",
  "type": "module",
  "license": "MIT",
  "author": "Takara",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takara-ai/miru-code.git"
  },
  "homepage": "https://takara.ai",
  "bugs": "https://github.com/takara-ai/miru-code/issues",
  "keywords": [
    "code-search",
    "semantic-search",
    "hybrid-search",
    "mcp",
    "embeddings",
    "bm25",
    "bun",
    "agents",
    "cursor",
    "takara"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "bin": {
    "miru": "./src/cli.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "grammars",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "miru": "bun run src/cli.ts",
    "mcp": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "vendor-grammars": "bun run scripts/vendor-grammars.ts",
    "prepublishOnly": "bun run vendor-grammars && bun run typecheck && bun test",
    "benchmark:ab": "bun run scripts/search-ab-local.ts",
    "benchmark:ab-multi": "bun run scripts/search-ab-multi.ts",
    "benchmark:recall": "bun run scripts/benchmark-recall-tokens.ts",
    "benchmark:vs-grep": "bun run scripts/benchmark-miru-vs-grep.ts",
    "benchmark:workflow": "bun run scripts/benchmark-workflow-tokens.ts",
    "benchmark:quality": "bun run scripts/benchmark-quality.ts",
    "benchmark:quantization": "bun run scripts/benchmark-quantization.ts"
  },
  "dependencies": {
    "ignore": "^7.0.5",
    "web-tree-sitter": "^0.26.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "^1.3.14",
    "tree-sitter-bash": "^0.25.1",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.5",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-css": "^0.25.0",
    "tree-sitter-dart": "^1.0.0",
    "tree-sitter-elixir": "^0.3.5",
    "tree-sitter-embedded-template": "^0.25.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-haskell": "^0.23.1",
    "tree-sitter-html": "^0.23.2",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-json": "^0.24.8",
    "tree-sitter-ocaml": "^0.24.2",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-scala": "^0.24.0",
    "tree-sitter-solidity": "^1.2.13",
    "tree-sitter-typescript": "^0.23.2",
    "typescript": "^6.0.3",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
